# Supabase / Lovable Cloud publishable config.
# These are public values (safe in the browser bundle); RLS protects your data.
# On Lovable, this file is auto-generated as `.env` — you do not need to fill it in.
# For local clones outside Lovable, copy to `.env` and fill in from your backend dashboard.

SUPABASE_PROJECT_ID=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_URL=
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=
